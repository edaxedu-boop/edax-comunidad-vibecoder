# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="tu_clave_gemini_aqui"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# ==========================================
# CLAVES DE INTEGRACIÓN DE PAGOS (MERCADO PAGO)
# ==========================================
# IMPORTANTE: Nunca expongas estas claves en el código del frontend (React). 
# Siempre debes usarlas desde el backend (ej. Serverless Functions de Vercel).

# Tu Access Token de Mercado Pago (Pruebas o Producción)
MP_ACCESS_TOKEN="tu_access_token_aqui"

# Tu Public Key de Mercado Pago (Opcional si usas el SDK en frontend)
MP_PUBLIC_KEY="tu_public_key_aqui"
